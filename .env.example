# Database connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/addallcrm

# JWT secret for authentication tokens (required)
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-random-secret-key-here

# Server port
PORT=3000

# iBiznes sync (MySQL connection to iBiznes ERP)
# IBIZNES_DB_URL=mysql://user:password@host:3306/dbname

# KSeF (Krajowy System e-Faktur) — pobieranie faktur kosztowych
# KSEF_ENV:   test (https://api-test.ksef.mf.gov.pl) | demo | prod
# KSEF_NIP:   10-cyfrowy NIP firmy w kontekście której działa token
# KSEF_TOKEN: PEŁNA wartość z eksportu panelu KSeF 2.0 w postaci
#             {numerReferencyjny}|nip-{NIP}|{hash}
#             Sam hash (bez prefiksu) zwraca "Invalid token encoding".
# KSEF_ENV=prod
# KSEF_NIP=1234567890
# KSEF_TOKEN=20260101-EC-XXXXXXXXXX-YYYYYYYYYY-ZZ|nip-1234567890|deadbeef...your-token-hash
