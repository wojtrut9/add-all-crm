# Database connection (PostgreSQL)
# On Replit: automatically provided via Replit DB
DATABASE_URL=postgresql://user:password@localhost:5432/addallcrm

# JWT secret for authentication tokens
# Use any random string (e.g. generate with: openssl rand -hex 32)
SESSION_SECRET=your-random-secret-key-here

# Server port (Replit uses 5000)
PORT=5000
